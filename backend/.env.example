DATABASE_URL=postgres://postgres:password@localhost:5432/coupang_review_ai
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=86400
SERVER_PORT=8080
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# 크롤러 모드: http(기본, 실제 쿠팡) | mock(픽스처 리뷰, 로컬 데모용)
CRAWLER_MODE=http
# 스크래핑 API 프록시(선택). {url} 에 타겟 URL 이 치환된다. 예: ScraperAPI/ZenRows
# 설정 시 모든 크롤링이 프록시 경유(anti-bot/IP 로테이션을 벤더가 처리).
# COUPANG_PROXY_URL=https://api.scraperapi.com/?api_key=YOUR_KEY&url={url}
